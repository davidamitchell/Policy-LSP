{
  "lspServers": {
    "gov-lsp": {
      "command": "GOV_LSP_BINARY",
      "args": ["-policies", "GOV_LSP_POLICIES", "-trace-file", "GOV_LSP_TRACE"],
      "fileExtensions": {
        ".md": "markdown",
        ".go": "go",
        ".sh": "shellscript",
        ".rego": "rego"
      }
    }
  }
}
